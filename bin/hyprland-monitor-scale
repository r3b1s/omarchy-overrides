#!/usr/bin/env sh
set -eu

case "${1:-}" in
  in|out) ;;
  *)
    notify-send "󰍹    Error: zoom value not specified"
    exit 1
    ;;
esac

script_path=$(readlink -f -- "$0")
root_dir=$(dirname -- "$(dirname -- "$script_path")")

hyprctl eval "package.path = [[${root_dir}/?.lua;]] .. package.path; package.loaded['hypr.actions'] = nil; require('hypr.actions').scale_monitor([[$1]])"
