#!/bin/bash
# omarchy:summary=Open the Neowall wallpaper/shader selector
# omarchy:aliases=omarchy neowall select
# omarchy:examples=SUPER+CTRL+ALT+SPACE -> omarchy-neowall-select

# Native Neowall selector workflow.
# Reuses Omarchy's image-selector UI (omarchy-menu-images + select-by-image.qml)
# to browse shader presets and compatible static wallpapers.
#
# Preview/posters are generated by seed-previews.sh (run during install).
# This script only reads pre-existing previews — no ImageMagick at selector time.

set -euo pipefail

DOTS="${HOME}/.local/share/omarchy-overrides"
CURRENT_THEME_NAME=$(cat "$HOME/.config/omarchy/current/theme.name" 2>/dev/null || true)

# Collect Omarchy wallpaper directories to include alongside shader previews
OMARCHY_DIRS=""
add_omarchy_dir() {
  local d="$1"
  if [[ -d "$d" ]]; then
    if [[ ":${OMARCHY_DIRS}:" != *":${d}:"* ]]; then
      OMARCHY_DIRS="${OMARCHY_DIRS}:${d}"
    fi
  fi
}

add_omarchy_dir "${HOME}/.config/omarchy/current/theme/backgrounds"
if [[ -n "$CURRENT_THEME_NAME" ]]; then
  add_omarchy_dir "${HOME}/.config/omarchy/backgrounds/${CURRENT_THEME_NAME}"
fi

# Build the list of directories for the image selector
SELECTOR_DIRS=""

# 1. Repo-managed previews (from presets, seeded by seed-previews.sh)
if [[ -d "${DOTS}/neowall/previews" ]] && \
   [[ "$(find "${DOTS}/neowall/previews" -maxdepth 1 -name '*.png' | wc -l)" -gt 0 ]]; then
  SELECTOR_DIRS="${SELECTOR_DIRS}:${DOTS}/neowall/previews"
fi

# 2. User config previews (bundled shaders, seeded by seed-previews.sh)
if [[ -d "${HOME}/.config/neowall/previews" ]] && \
   [[ "$(find "${HOME}/.config/neowall/previews" -maxdepth 1 -name '*.png' | wc -l)" -gt 0 ]]; then
  if [[ ":${SELECTOR_DIRS}:" != *":${HOME}/.config/neowall/previews:"* ]]; then
    SELECTOR_DIRS="${SELECTOR_DIRS}:${HOME}/.config/neowall/previews"
  fi
fi

# 3. Omarchy wallpaper directories
if [[ -n "$OMARCHY_DIRS" ]]; then
  SELECTOR_DIRS="${SELECTOR_DIRS}${OMARCHY_DIRS}"
fi

SELECTOR_DIRS="${SELECTOR_DIRS#:}"
if [[ -z "$SELECTOR_DIRS" ]]; then
  omarchy-notification-send "No wallpapers or shader previews found" -t 3000
  exit 1
fi

IFS=':' read -ra DIRS <<< "$SELECTOR_DIRS"

# Launch the image selector (reuse Omarchy's UI)
SELECTED=$(omarchy-menu-images \
  --show-labels \
  --filterable \
  --lazy-thumbnails \
  "${DIRS[@]}")

if [[ -z "$SELECTED" ]]; then
  exit 0
fi

# Resolve and apply the selection via omarchy-neowall-apply
"${DOTS}/bin/omarchy-neowall-apply" --from-preview "$SELECTED" || {
  omarchy-notification-send "Failed to apply Neowall entry" -t 3000
  exit 1
}

omarchy-notification-send "Neowall applied: $(basename "$SELECTED")" -t 2000
