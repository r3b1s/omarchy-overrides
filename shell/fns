# Relink custom executables to user's bin/ folder
linkbin () {
  local DOTS_BIN=$HOME/.local/share/omarchy-overrides/bin
  local LOCAL_BIN=$HOME/.local/bin

  for f in "$DOTS_BIN"/*; do
    local file=$(basename "$f")
    echo "Linking $file..."
    rm -v "$LOCAL_BIN"/"$file"
    ln -s -v "$DOTS_BIN"/"$file" "$LOCAL_BIN"/"$file"
  done
}

# openssl with pkcs11 provider (smart card + hsm support)
ossl () {
  local OPENSSL_CONF=$HOME/.local/share/omarchy-overrides/openssl/openssl-pkcs11.cnf
  openssl "$@"
}
