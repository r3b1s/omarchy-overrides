# Tmux dev layout functions
# Source this in your shell config: source ~/.local/share/omarchy-overrides/tmux/tmux_fns
#
# Create 3 vertical panes with roughly equal width (33/34/33)
# Usage: tvl [target-pane] [directory]
tvl() {
  local target="${1:-$TMUX_PANE}"
  local current_dir="${2:-$PWD}"

  [[ -z $target ]] && { echo "You must start tmux to use tvl."; return 1; }

  tmux rename-window -t "$target" "$(basename "$current_dir")"

  # Create two additional vertical panes
  tmux split-window -h -t "$target" -c "$current_dir"
  tmux split-window -h -t "$target" -c "$current_dir"

  # Even out all pane widths using the even-horizontal layout
  tmux select-layout -t "$target" even-horizontal
}
