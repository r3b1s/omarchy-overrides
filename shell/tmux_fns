# Tmux dev layout functions
# Source this in your shell config: source ~/.local/share/omarchy-overrides/tmux/tmux_fns


# Create 3 vertical panes with roughly equal width (33/34/33)
# Usage: tvl [session-name] [directory]
#   No args outside tmux → create & attach new session ("tvl-$$")
#   Name provided outside tmux → create & attach new session with that name
#
#   No args inside tmux → layout the current window
#   Name provided inside tmux → create & switch to new session with that name
tvl() {
  local session_name="${1:-}"
  local current_dir="${2:-$PWD}"
  local target
  local session=""

  # [[ -z $target ]] && { echo "You must start tmux to use tvl."; return 1; }

  if [[ -z $TMUX ]]; then
    # Outside tmux — create new session
    session="${session_name:-tvl-$$}"
    tmux new-session -ds "$session" -c "$current_dir"
    target=$(tmux display-message -p -t "$session:0.0" "#{pane_id}")
  elif [[ -n $session_name ]]; then
    # Inside tmux with a name — create a new session
    session="$session_name"
    tmux new-session -ds "$session" -c "$current_dir"
    target=$(tmux display-message -p -t "$session:0.0" "#{pane_id}")
  else
    # Inside tmux, no name — use current pane
    target="$TMUX_PANE"
  fi

  tmux rename-window -t "$target" "$(basename "$current_dir")"

  # Create two additional vertical panes
  tmux split-window -h -t "$target" -c "$current_dir"
  tmux split-window -h -t "$target" -c "$current_dir"

  # Even out all pane widths using the even-horizontal layout
  tmux select-layout -t "$target" even-horizontal

  # Attach or switch based on context
  if [[ -z $TMUX && -n $session ]]; then
    tmux attach-session -t "$session"
  elif [[ -n $TMUX && -n $session ]]; then
    tmux switch-client -t "$session"
  fi
}

