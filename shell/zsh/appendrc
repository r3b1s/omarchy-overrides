# ----- appended ----- omarchy-overrides -----

# zsh settings
bindkey -v # vi mode

# Ghostty shell integration (ssh wrapper, terminfo, cursor, etc.)
source /usr/share/ghostty/shell-integration/zsh/ghostty-integration

# sourcing
export RTK_TELEMETRY_DISABLED=1
source $HOME/.local/share/omarchy-overrides/shell/envs # env vars
source $DOTS/shell/aliases # aliases
source $DOTS/shell/fns # functions
source $DOTS/shell/other # everything else
