#!/usr/bin/env bash
# Symlink this repo into ~/.local/share/omarchy-overrides
#
# Run from within the repo to register it at the expected
# system location.  The repo can live anywhere (e.g. your
# personal projects directory); this script creates the
# single symlink that makes everything else find it.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
TARGET="${HOME}/.local/share/omarchy-overrides"

# --- safety checks ---

if [[ ! -f "${REPO_ROOT}/shell/envs" ]]; then
  echo "error: doesn't look like the omarchy-overrides repo root (${REPO_ROOT})" >&2
  exit 1
fi

if [[ -L "$TARGET" ]]; then
  EXISTING="$(readlink "$TARGET")"
  if [[ "$EXISTING" == "$REPO_ROOT" ]]; then
    echo "already linked: $TARGET → $REPO_ROOT"
    exit 0
  fi
  echo "warning: $TARGET is already a symlink pointing elsewhere ($EXISTING)" >&2
  echo "overwrite with: $TARGET → $REPO_ROOT ? [y/N] " >&2
  read -r ok
  if [[ "$ok" != "y" && "$ok" != "Y" ]]; then
    echo "aborted."
    exit 1
  fi
  rm "$TARGET"

elif [[ -e "$TARGET" ]]; then
  echo "error: $TARGET exists and is not a symlink — move it aside first" >&2
  exit 1
fi

# --- create parent & symlink ---

mkdir -p "$(dirname "$TARGET")"
ln -s "$REPO_ROOT" "$TARGET"

echo "linked: $TARGET → $REPO_ROOT"
